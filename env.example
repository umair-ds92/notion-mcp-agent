# ── Required ─────────────────────────────────────────────
OPENAI_API_KEY=sk-...
NOTION_API_KEY=ntn_...

# ── Optional ─────────────────────────────────────────────
OPENAI_MODEL=o4-mini
AGENT_MAX_TURNS=5
MCP_READ_TIMEOUT=20
PORT=7001

# Logging: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Retry
RETRY_MAX_ATTEMPTS=3
RETRY_BASE_DELAY=1.0
RETRY_MAX_DELAY=8.0

# Ngrok (optional)
NGROK_AUTH_TOKEN=